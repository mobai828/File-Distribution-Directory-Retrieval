+                            btn.classList.remove('btn-primary');
+                            btn.classList.add('btn-outline-primary');
+                        }
+                    });
+                    
+                    document.querySelectorAll('.stop-tts-btn').forEach(btn => {
+                        btn.classList.add('d-none');
